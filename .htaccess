# .htaccess - Funciona en local (subdir Publicidad) y en producción (raíz dominio)

Options -Indexes
Options -MultiViews
AddDefaultCharset UTF-8

# ===========================================================================
# Solo permitir trafico desde Cloudflare en produccion (placerselecto.com).
# En local (Laragon: localhost / *.test / *.local) la condicion <If> no aplica
# y el sitio funciona normal.
#
# Lista de rangos: https://www.cloudflare.com/ips/ — actualizar 1-2 veces al ano.
# Si CF cambia rangos y el sitio se rompe, comentar este bloque y redeployar.
# ===========================================================================
<If "%{HTTP_HOST} =~ /placerselecto\.com$/i">
    <RequireAny>
        Require ip 173.245.48.0/20
        Require ip 103.21.244.0/22
        Require ip 103.22.200.0/22
        Require ip 103.31.4.0/22
        Require ip 141.101.64.0/18
        Require ip 108.162.192.0/18
        Require ip 190.93.240.0/20
        Require ip 188.114.96.0/20
        Require ip 197.234.240.0/22
        Require ip 198.41.128.0/17
        Require ip 162.158.0.0/15
        Require ip 104.16.0.0/13
        Require ip 104.24.0.0/14
        Require ip 172.64.0.0/13
        Require ip 131.0.72.0/22
        Require ip 2400:cb00::/32
        Require ip 2606:4700::/32
        Require ip 2803:f800::/32
        Require ip 2405:b500::/32
        Require ip 2405:8100::/32
        Require ip 2a06:98c0::/29
        Require ip 2c0f:f248::/32
        # Loopback del propio servidor (para cron jobs y health-checks internos)
        Require ip 127.0.0.1
        Require ip ::1
    </RequireAny>
</If>

<IfModule mod_rewrite.c>
    RewriteEngine On

    # No fijar RewriteBase: Apache infiere automáticamente
    # En local (subdir) y en producción (raíz) ambos funcionan.

    RewriteCond %{REQUEST_FILENAME} !-f
    RewriteCond %{REQUEST_FILENAME} !-d
    RewriteRule ^(.*)$ index.php [QSA,L]
</IfModule>

<FilesMatch "\.(env|env\.local\.php|env\.production\.php|env\.development\.php|log|sql|bak|sh|json|lock|md|htaccess|gitignore|gitattributes|yml)$">
    Require all denied
</FilesMatch>

<IfModule mod_rewrite.c>
    RewriteRule ^(app|config|logs|routes|\.git)/.*$ - [F,L]
</IfModule>

<IfModule mod_headers.c>
    # Inyectar unsafe-inline en CSP del hosting (sin fallar si no aplica)
    Header edit Content-Security-Policy "script-src" "script-src 'unsafe-inline' 'unsafe-eval'"

    Header set X-Frame-Options "DENY"
    Header set X-Content-Type-Options "nosniff"
    Header set Referrer-Policy "strict-origin-when-cross-origin"
</IfModule>

<IfModule mod_deflate.c>
    AddOutputFilterByType DEFLATE text/html text/css application/javascript application/json
</IfModule>

<IfModule mod_expires.c>
    ExpiresActive On
    ExpiresByType image/jpeg "access plus 1 month"
    ExpiresByType image/png  "access plus 1 month"
    ExpiresByType image/webp "access plus 1 month"
    ExpiresByType text/css   "access plus 1 week"
    ExpiresByType application/javascript "access plus 1 week"
</IfModule>

ServerSignature Off
